const cmap={cyan:'var(--cyan)',grn:'var(--grn)',amb:'var(--amb)',pur:'var(--pur)',red:'var(--red)',blu:'var(--blu)'};
const wg=document.getElementById('weekGrid');
const dd=document.getElementById('dayDetail');
let open=-1;

DAYS.forEach((d,i)=>{
  const total=d.blocks.reduce((a,b)=>a+b.tasks.length,0);
  const el=document.createElement('div');
  el.className='day-card';
  el.innerHTML=`<div class="day-arrow">▶</div>
    <div class="day-name" style="color:${d.color}">${d.name}</div>
    <div class="day-preview">${d.blocks[0].tasks[0].t.substring(0,44)}...</div>
    <div class="day-count" style="background:${d.color}18;border:1px solid ${d.color}30;color:${d.color}">${total} tareas</div>`;
  el.onclick=()=>toggle(i,el);
  wg.appendChild(el);
});

function toggle(i,card){
  const all=document.querySelectorAll('.day-card');
  if(open===i){card.classList.remove('open');dd.innerHTML='';open=-1;return;}
  all.forEach(c=>c.classList.remove('open'));
  card.classList.add('open');
  open=i;
  const d=DAYS[i];
  let h=`<div class="day-expanded show" style="border-color:${d.color}30">
    <div class="day-exp-title" style="color:${d.color}">${d.name}</div>`;
  d.blocks.forEach(b=>{
    h+=`<div class="task-block"><div class="block-title">${b.title}</div>`;
    b.tasks.forEach(t=>{
      h+=`<div class="task-item"><div class="tdot ${b.dot}"></div>
        <div><div class="task-txt">${t.t}</div><div class="task-sub">🔧 ${t.s}</div></div>
      </div>`;
    });
    h+=`</div>`;
  });
  h+=`</div>`;
  dd.innerHTML=h;
  setTimeout(()=>dd.scrollIntoView({behavior:'smooth',block:'start'}),60);
}
